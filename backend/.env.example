# Copy to backend/.env and fill real values. .env is gitignored.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Supabase → Settings → Database → Connection string (URI). Leave blank to use sqlite locally.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Razorpay → Dashboard → API Keys (test mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Razorpay → Webhooks → the secret you set when creating the webhook
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Production only (DEBUG=False): comma-separated
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Reminder providers — leave blank to disable (send_reminders logs 'no_provider')
GUPSHUP_API_KEY=
GUPSHUP_SOURCE=
GUPSHUP_APP=
MSG91_API_KEY=

# Firebase phone-auth: path to the service-account JSON (verifies OTP tokens at registration)
FIREBASE_CREDENTIALS=










